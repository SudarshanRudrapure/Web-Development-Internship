## Example SQL syntax-Oracle

-- Creates customers table
CREATE TABLE customers (
    customer_id NUMBER PRIMARY KEY,
    name VARCHAR2(100) NOT NULL,
    address VARCHAR2(100),
    website VARCHAR2(100),
    created_limit NUMBER(8, 2)
);

